  "texts": {
    "ru": {
      "text": "Любовь и труд неразделимы: мы любим то, над чем трудимся, и трудимся над тем, что любим",
      "highlight": "Любовь и труд неразделимы",
      "status": "source"
    },
    "en": {
      "text": "Love and work are inseparable: we love what we work on, and we work on what we love",
      "highlight": "Love and work are inseparable",
      "status": "translated"
    },
    "de": {
      "text": "Liebe und Arbeit sind untrennbar: Wir lieben, woran wir arbeiten, und wir arbeiten an dem, was wir lieben",
      "highlight": "Liebe und Arbeit sind untrennbar",
      "status": "translated"
    },
    "fi": {
      "text": "Rakkaus ja työ ovat erottamattomat: rakastamme sitä, minkä parissa työskentelemme, ja työskentelemme sen parissa, mitä rakastamme",
      "highlight": "Rakkaus ja työ ovat erottamattomat",
      "status": "translated"
    },
    "cn": {
      "text": "爱与劳动不可分割：我们爱我们为之努力的，也为我们所爱的努力",
      "highlight": "爱与劳动不可分割",
      "status": "translated"
    }
  },
